import matplotlib.pyplot as plt
from sklearn.datasets import load_iris
from sklearn.model_selection import train_test_split
from sklearn.ensemble import BaggingClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.metrics import accuracy_score

# Load data
iris = load_iris()
X_train, X_test, y_train, y_test = train_test_split(iris.data, iris.target, test_size=0.3, random_state=42)

# 8A. Bagging Model
# Using 10 decision trees as base estimators
model = BaggingClassifier(estimator=DecisionTreeClassifier(), n_estimators=10, random_state=42)
model.fit(X_train, y_train)

# Output
y_pred = model.predict(X_test)
print(f"Bagging Accuracy: {accuracy_score(y_test, y_pred)*100:.2f}%")

# Visualization: Compare individual tree accuracy vs ensemble accuracy
plt.figure(figsize=(8, 5))
plt.bar(['Bagging Ensemble'], [accuracy_score(y_test, y_pred)], color='skyblue')
plt.ylabel('Accuracy')
plt.title('Performance of Bagging Technique')
plt.ylim(0, 1)
plt.show()